; Engine configuration file.
; Salamia: Grassroots Rising — Spike build.

config_version=5

[application]

config/name="Salamia: Grassroots Rising"
config/description="A political simulation set in the federal republic of Salamia. Spike build: Aryavarta state, Volunteer → Councillor arc."
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/game_state.gd"
ScenarioLoader="*res://scripts/scenario_loader.gd"
Palette="*res://scripts/palette.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.957, 0.894, 0.776, 1)
textures/canvas_textures/default_texture_filter=1
anti_aliasing/quality/msaa_2d=2

[gui]

theme/default_font_antialiasing=1
theme/default_font_hinting=1
theme/default_font_subpixel_positioning=1
